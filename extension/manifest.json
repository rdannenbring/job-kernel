{
  "manifest_version": 3,
  "name": "Job Application Automator Extension",
  "version": "1.0.0",
  "description": "Capture job listings and automatically start processing them in the Job Application Automator.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "scripting",
    "contextMenus",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": "icons/icon48.png",
    "default_title": "Open Automator Panel"
  }
}
